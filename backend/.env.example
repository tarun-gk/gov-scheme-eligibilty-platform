NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace-with-local-db-password
DB_NAME=gov_scheme_eligibility

JWT_ACCESS_SECRET=replace-with-32-char-min-secret
JWT_REFRESH_SECRET=replace-with-32-char-min-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=scheme_embeddings
FRONTEND_ORIGIN=http://localhost:5173

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_IP=120
API_RATE_LIMIT_MAX_USER=300
CACHE_TTL_SECONDS=600

NOTIFICATION_PROVIDER_URL=
